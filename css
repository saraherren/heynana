body {
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(#f8c8dc, #fff1e6);
  color: #1a1a1a;
  text-align: center;
}

header {
  padding: 2rem;
}

.card {
  background: white;
  border-radius: 20px;
  padding: 1.5rem;
  margin: 1rem;
  box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  display: inline-block;
  width: 200px;
  transition: transform 0.2s;
}

.card:hover {
  transform: scale(1.05);
}
